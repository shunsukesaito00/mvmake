{
  "name": "fable",
  "private": true,
  "version": "1.3.0",
  "description": "ブラウザ完結型の結婚式ムービー編集アプリ。サーバー不要、すべての処理はローカルで実行。",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:prod": "E2E_BASE_URL=https://shunsukesaito00.github.io/mvmake/ playwright test e2e/basic.spec.ts",
    "preview": "vite preview",
    "screenshot": "playwright test --config playwright.screenshot.config.ts"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "mp4-muxer": "^5.2.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uuid": "^14.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
